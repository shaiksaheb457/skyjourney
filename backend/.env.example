# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# For local MongoDB (use this for now):
MONGO_URI=mongodb://localhost:27017/skyjourney

# For MongoDB Atlas (use this when deploying):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/skyjourney

# ── JWT ───────────────────────────────────────────────────────
# Any long random string — keep it secret!
JWT_SECRET=myskyjourneysupersecretkey12345abcdef
JWT_EXPIRE=7d

# ── Email (Nodemailer via Gmail) ──────────────────────────────
# Gmail → Manage Account → Security → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password
FROM_NAME=SkyJourney
FROM_EMAIL=noreply@skyjourney.com

# ── Razorpay ──────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Stripe ───────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# ── Frontend URL (for CORS) ───────────────────────────────────
CLIENT_URL=http://localhost:5173